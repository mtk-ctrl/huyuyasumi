{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lifequest-sync",
  "main": "src/index.js",
  "compatibility_date": "2026-07-12",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lifequest-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://mtk-ctrl.github.io,https://htmlpreview.github.io"
  }
}
